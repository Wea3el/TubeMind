  <graph edgedefault="undirected">
    <node id="Calypso">
      <data key="d0">Calypso</data>
      <data key="d1">creature</data>
      <data key="d2">Calypso is the title of an entry in the 11th edition of Encyclopædia Britannica.&lt;SEP&gt;Calypso is a figure from ancient Greek mythology who is associated with love for Odysseus and is interpreted in literature and philosophy.&lt;SEP&gt;Calypso is a nymph in Greek mythology who lives on the island of Ogygia, detains Odysseus for seven years, offers him immortality, and is variously described as the daughter of Atlas, an Oceanid, a Nereid, or a daughter of Helios and Perse; she is associated with concealment and reclusiveness.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269&lt;SEP&gt;chunk-67499e7b6b869922afb829c43d6b368e&lt;SEP&gt;chunk-33ca7b8a64b97232ad237017f77a125a</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Ogygia">
      <data key="d0">Ogygia</data>
      <data key="d1">location</data>
      <data key="d2">Ogygia is the island where Calypso lives and where Odysseus is detained for seven years in the Odyssey.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Odysseus">
      <data key="d0">Odysseus</data>
      <data key="d1">person</data>
      <data key="d2">Odysseus is a figure from ancient Greek mythology whose relationship with Calypso inspires accounts of her love and yearning.&lt;SEP&gt;Odysseus is a fabled Greek hero who is detained by Calypso on Ogygia for seven years, longs to return to his wife Penelope, and is eventually ordered freed by the gods.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269&lt;SEP&gt;chunk-67499e7b6b869922afb829c43d6b368e</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Homer">
      <data key="d0">Homer</data>
      <data key="d1">person</data>
      <data key="d2">Homer is the ancient Greek poet credited with composing the Odyssey, which is referenced in several works.&lt;SEP&gt;Homer is the attributed author of the Odyssey, which recounts the story of Calypso detaining Odysseus on Ogygia.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269&lt;SEP&gt;chunk-67499e7b6b869922afb829c43d6b368e</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Odyssey">
      <data key="d0">Odyssey</data>
      <data key="d1">content</data>
      <data key="d2">The Odyssey is an epic poem attributed to Homer that describes, among other events, Calypso detaining Odysseus on Ogygia and his eventual release.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Immortality">
      <data key="d0">Immortality</data>
      <data key="d1">concept</data>
      <data key="d2">Immortality is the state of living forever, which Calypso promises to grant Odysseus if he stays with her.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Greek Mythology">
      <data key="d0">Greek Mythology</data>
      <data key="d1">content</data>
      <data key="d2">Greek Mythology is the body of myths from ancient Greece in which Calypso, Odysseus, and other gods and nymphs appear.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Etymologicum Magnum">
      <data key="d0">Etymologicum Magnum</data>
      <data key="d1">content</data>
      <data key="d2">Etymologicum Magnum is a medieval dictionary that interprets Calypso's name as meaning 'concealing the knowledge'.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Dolóessa">
      <data key="d0">Dolóessa</data>
      <data key="d1">concept</data>
      <data key="d2">Dolóessa is a Homeric epithet meaning 'subtle' or 'wily' that is associated with Calypso and used to justify her reclusive character.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Atlas">
      <data key="d0">Atlas</data>
      <data key="d1">creature</data>
      <data key="d2">Atlas is a Titan who is generally said to be the father of Calypso.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428709</data>
      <data key="d6" />
    </node>
    <node id="Fabulae">
      <data key="d0">Fabulae</data>
      <data key="d1">content</data>
      <data key="d2">Fabulae is a work that describes Calypso as the daughter of Pleione, differing from other accounts of her parentage.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Pleione">
      <data key="d0">Pleione</data>
      <data key="d1">creature</data>
      <data key="d2">Pleione is the mother of the Pleiades and, according to the Fabulae, the mother of Calypso.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Pleiades">
      <data key="d0">Pleiades</data>
      <data key="d1">creature</data>
      <data key="d2">Pleiades are the daughters of Pleione, mentioned as part of Pleione's family when describing Calypso's possible parentage.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Hesiod">
      <data key="d0">Hesiod</data>
      <data key="d1">person</data>
      <data key="d2">Hesiod is an ancient Greek poet whose works Theogony and The Shield and other fragments are referenced.&lt;SEP&gt;Hesiod is an ancient Greek poet who mentions a Calypso as one of the Oceanid nymphs, daughter of Tethys and Oceanus.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269&lt;SEP&gt;chunk-67499e7b6b869922afb829c43d6b368e</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Homeric Hymn to Demeter">
      <data key="d0">Homeric Hymn to Demeter</data>
      <data key="d1">content</data>
      <data key="d2">The Homeric Hymn to Demeter is an ancient Greek hymn whose anonymous author mentions a Calypso as one of the Oceanid nymphs.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Oceanid Nymphs">
      <data key="d0">Oceanid Nymphs</data>
      <data key="d1">creature</data>
      <data key="d2">Oceanid nymphs are daughters of Tethys and Oceanus, among whom some sources include a Calypso.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Tethys">
      <data key="d0">Tethys</data>
      <data key="d1">creature</data>
      <data key="d2">Tethys is a goddess who, with Oceanus, is parent to the Oceanid nymphs, including a Calypso in some accounts.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Oceanus">
      <data key="d0">Oceanus</data>
      <data key="d1">creature</data>
      <data key="d2">Oceanus is a god who, with Tethys, is parent to the Oceanid nymphs, including a Calypso in some accounts.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Apollodorus">
      <data key="d0">Apollodorus</data>
      <data key="d1">person</data>
      <data key="d2">Apollodorus is an author associated with the work The Library, cited in the references concerning Calypso.&lt;SEP&gt;Apollodorus is an author who includes Calypso in a list of Nereids, daughters of Nereus and Doris.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269&lt;SEP&gt;chunk-67499e7b6b869922afb829c43d6b368e</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Nereids">
      <data key="d0">Nereids</data>
      <data key="d1">creature</data>
      <data key="d2">Nereids are sea nymphs, daughters of Nereus and Doris, and a group in which Apollodorus lists Calypso.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Nereus">
      <data key="d0">Nereus</data>
      <data key="d1">creature</data>
      <data key="d2">Nereus is a sea god who, with Doris, is parent to the Nereids, among whom Calypso is sometimes listed.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Doris">
      <data key="d0">Doris</data>
      <data key="d1">creature</data>
      <data key="d2">Doris is a figure who, with Nereus, is parent to the Nereids, including Calypso in some accounts.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="John Tzetzes">
      <data key="d0">John Tzetzes</data>
      <data key="d1">person</data>
      <data key="d2">John Tzetzes is a scholar who makes Calypso a daughter of Helios and Perse, linking her family to Circe.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Helios">
      <data key="d0">Helios</data>
      <data key="d1">creature</data>
      <data key="d2">Helios is the sun-god who, with Perse, is said by John Tzetzes to be the father of Calypso and Circe.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Perse">
      <data key="d0">Perse</data>
      <data key="d1">creature</data>
      <data key="d2">Perse is an Oceanid nymph who, with Helios, is said by John Tzetzes to be the mother of Calypso and Circe.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428710</data>
      <data key="d6" />
    </node>
    <node id="Circe">
      <data key="d0">Circe</data>
      <data key="d1">creature</data>
      <data key="d2">Circe is a goddess, daughter of Helios and Perse, associated with Odysseus and sometimes confused with Calypso due to similar behavior and connections.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Catalogue of Women">
      <data key="d0">Catalogue of Women</data>
      <data key="d1">content</data>
      <data key="d2">Catalogue of Women is an ancient work from which a fragment reports that Calypso bore the Cephalonians to Hermes.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Cephalonians">
      <data key="d0">Cephalonians</data>
      <data key="d1">creature</data>
      <data key="d2">Cephalonians are a people said in a fragment from the Catalogue of Women to have been borne by Calypso to Hermes.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Hermes">
      <data key="d0">Hermes</data>
      <data key="d1">creature</data>
      <data key="d2">Hermes is a god who visits Calypso's island in the Odyssey, is ordered by Zeus to tell her to free Odysseus, and in one fragment fathers the Cephalonians with her.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Penelope">
      <data key="d0">Penelope</data>
      <data key="d1">person</data>
      <data key="d2">Penelope is the wife of Odysseus, from whom he is separated while detained by Calypso and to whom he wishes to return.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Athena">
      <data key="d0">Athena</data>
      <data key="d1">creature</data>
      <data key="d2">Athena is the patron goddess of Odysseus who asks Zeus to order his release from Calypso's island.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Zeus">
      <data key="d0">Zeus</data>
      <data key="d1">creature</data>
      <data key="d2">Zeus is the chief god who orders Hermes to tell Calypso to set Odysseus free, declaring that Odysseus is not destined to live with her forever.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Latinus">
      <data key="d0">Latinus</data>
      <data key="d1">person</data>
      <data key="d2">Latinus is a son who in some accounts is borne by Calypso to Odysseus, though more commonly attributed to Circe.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Nausithous">
      <data key="d0">Nausithous</data>
      <data key="d1">person</data>
      <data key="d2">Nausithous is one of two children that some accounts say Calypso bore to Odysseus.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Nausinous">
      <data key="d0">Nausinous</data>
      <data key="d1">person</data>
      <data key="d2">Nausinous is one of two children that some accounts say Calypso bore to Odysseus.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Gilgamesh">
      <data key="d0">Gilgamesh</data>
      <data key="d1">person</data>
      <data key="d2">Gilgamesh is a hero whose interactions with Siduri in the Epic of Gilgamesh are compared to the story of Odysseus and Calypso.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Siduri">
      <data key="d0">Siduri</data>
      <data key="d1">creature</data>
      <data key="d2">Siduri is a female figure in the Epic of Gilgamesh who interacts with Gilgamesh in a way compared to Calypso's dealings with Odysseus.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Epic of Gilgamesh">
      <data key="d0">Epic of Gilgamesh</data>
      <data key="d1">content</data>
      <data key="d2">The Epic of Gilgamesh is an ancient Mesopotamian epic in which Gilgamesh meets Siduri, a scene compared to Odysseus and Calypso.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Poseidon">
      <data key="d0">Poseidon</data>
      <data key="d1">creature</data>
      <data key="d2">Poseidon is the sea-god who hates Odysseus for blinding his son Polyphemus and in one fragment is said to have Calypso detain Odysseus as a favour.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Polyphemus">
      <data key="d0">Polyphemus</data>
      <data key="d1">creature</data>
      <data key="d2">Polyphemus is a cyclops, son of Poseidon, who is blinded by Odysseus and whose injury causes Poseidon to detest Odysseus.</data>
      <data key="d3">chunk-4a9428bfe0806b900c71bbcf810ed269</data>
      <data key="d4">https://en.wikipedia.org/wiki/Calypso_(mythology)</data>
      <data key="d5">1772428711</data>
      <data key="d6" />
    </node>
    <node id="Cyclops">
      <data key="d0">Cyclops</data>
